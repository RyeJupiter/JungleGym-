{
  "name": "junglegym",
  "version": "0.0.1",
  "private": true,
  "description": "JungleGym - Distributed Personal Training Platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
